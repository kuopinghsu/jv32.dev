#!/bin/sh
set -eu

if [ "${1:-}" = "--version" ]; then
    # ACT4 checks Sail version exactly; keep compatibility.
    echo "0.10"
    exit 0
fi

sig_file=""
sig_granularity="4"
elf=""

while [ "$#" -gt 0 ]; do
    case "$1" in
        --trace-all)
            shift
            ;;
        --trace-output)
            # Trace output file (Sail-only) is ignored by spike backend.
            shift 2
            ;;
        --config)
            # Sail JSON config is ignored by spike backend.
            shift 2
            ;;
        --test-signature=*)
            sig_file="${1#*=}"
            shift
            ;;
        --signature-granularity)
            sig_granularity="${2:-4}"
            shift 2
            ;;
        --*)
            shift
            ;;
        *)
            elf="$1"
            shift
            ;;
    esac
done

if [ -z "$elf" ] || [ -z "$sig_file" ]; then
    echo "sail wrapper error: missing ELF or --test-signature" >&2
    exit 2
fi

spike_isa="${SPIKE_ISA:-}"
if [ -z "$spike_isa" ]; then
    # Infer ISA width from ELF header so RV32 tests don't run on Spike's RV64 default.
    elf_class="$(LC_ALL=C file -b "$elf" 2>/dev/null || true)"
    case "$elf_class" in
        *ELF*32-bit*)
            spike_isa="rv32imac_zicntr_zicsr"
            ;;
        *ELF*64-bit*)
            spike_isa="rv64imac_zicntr_zicsr"
            ;;
        *)
            spike_isa="rv32imac"
            ;;
    esac
fi

exec "__SPIKE_BIN__" --isa="$spike_isa" "+signature=$sig_file" "+signature-granularity=$sig_granularity" "$elf"
