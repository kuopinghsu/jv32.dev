# Environment Configuration Template for JV32 RISC-V SoC Project
# Copy this file to env.config and edit for your machine:
#   cp env.config.template env.config
#
# The root Makefile auto-copies this template to env.config on first run.

# ============================================================================
# RISC-V Toolchain prefix
# Examples:
#   /home/user/opt/xpack-riscv-none-elf-gcc-15.2.0-1/bin/riscv-none-elf-
#   riscv64-unknown-elf-
#   riscv32-unknown-elf-
# ============================================================================
RISCV_PREFIX=$(HOME)/opt/riscv/bin/riscv64-unknown-elf-

# ============================================================================
# Verilator path
# Examples:
#   /usr/bin/verilator
#   /usr/local/bin/verilator
#   verilator  (if in PATH)
# ============================================================================
VERILATOR=$(HOME)/opt/verilator/bin/verilator

# ============================================================================
# Verible path (optional; set to 'None' or leave unset to skip Verible)
# Examples:
#   /opt/verible/bin/verible-verilog-lint
#   verible-verilog-lint  (if in PATH)
# ============================================================================
VERIBLE=verible-verilog-lint

# Verible formatter path (optional; set to 'None' or leave unset to skip formatting)
# Examples:
#   /opt/verible/bin/verible-verilog-format
#   verible-verilog-format  (if in PATH)
VERIBLE_FORMAT=verible-verilog-format

# ============================================================================
# svlint path (optional; set to 'None' or leave unset to skip svlint)
# Examples:
#   /opt/svlint/bin/svlint
#   svlint  (if in PATH)
# ============================================================================
SVLINT=$(HOME)/opt/svlint/bin/svlint

# ============================================================================
# Spike RISC-V ISA simulator (used for arch-test reference model)
# Examples:
#   /home/user/riscv-isa-sim/build/spike
#   spike  (if in PATH)
# ============================================================================
SPIKE=$(HOME)/opt/riscv/bin/spike

# ============================================================================
# Additional PATH directories (appended to PATH)
# Add paths to GTKWave, Yosys, or other EDA tools here.
# Examples:
#   /home/user/opt/oss-cad-suite/bin
# ============================================================================
PATH_APPEND=$(HOME)/opt/verible/bin

# ============================================================================
# ASIC Synthesis & P&R (syn/Makefile)
# ============================================================================

# OpenRAM 1.2.x memory compiler root directory (contains sram_compiler.py)
# Example: /home/user/OpenRAM-1.2.48
OPENRAM=$(HOME)/opt/OpenRAM

# OpenLane 2 root directory (source tree containing shell.nix and the
# 'openlane' Python package).
# Example: /home/user/opt/openlane2
#
# OpenLane2 dependencies (libparse, klayout, OpenROAD Python bindings, …) are
# resolved via Nix.  Before running 'make synth' for the first time, execute:
#   make syn-setup          ← pre-fetches Nix packages (~500 MB, once only)
#
# The default OPENLANE_CMD uses syn/scripts/openlane_nix.sh which wraps the
# invocation inside nix-shell automatically.  If you prefer a bare pip
# install, override OPENLANE_CMD:
#   OPENLANE_CMD=python3 -m openlane
OPENLANE=$(HOME)/opt/openlane2

# nix-shell binary (default: nix-shell from PATH).
# Only needed when using the Nix-based openlane_nix.sh wrapper.
# NIX_SHELL=/nix/var/nix/profiles/default/bin/nix-shell

# openlane run command — override to skip Nix and use a bare pip environment:
# OPENLANE_CMD=python3 -m openlane

# OpenROAD binary — used by 'make pnr' and 'make timing-report'
# Uses the Nix-shell wrapper (same Nix env as OPENLANE_CMD) so that all
# OpenROAD/OpenSTA dependencies are provided by Nix automatically.
# Set to 'openroad' if OpenROAD is installed system-wide and in PATH.
OPENROAD=$(SYN_DIR)/scripts/openroad_nix.sh

# Nangate 45nm Open Cell Library root (FreePDK45).
# Must contain: NangateOpenCellLibrary.tech.lef, .macro.lef, .gds
# Download from: https://www.eda.ncsu.edu/wiki/FreePDK45
# Example: /opt/FreePDK45/NangateOpenCellLibrary
NANGATE_HOME=$(HOME)/opt/nangate
