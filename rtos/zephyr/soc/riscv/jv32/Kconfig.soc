config SOC_RISCV_JV32
    bool "RISC-V jv32 SoC"
    select RISCV
    select RISCV_PRIVILEGED
    select RISCV_ISA_RV32I
    select RISCV_ISA_EXT_M
    select RISCV_ISA_EXT_A
    select RISCV_ISA_EXT_C
    select RISCV_ISA_EXT_ZICSR
    select RISCV_ISA_EXT_ZIFENCEI
    select RISCV_HAS_CPU_IDLE
    help
      Enable support for the custom RISC-V RV32IMAC jv32 SoC.
      This is a 3-stage single-issue pipeline with:
      - RV32I base integer instruction set
      - M extension (multiply/divide)
      - A extension (atomics/AMO)
      - C extension (compressed instructions)
      - 256KB RAM (128KB IRAM @ 0x80000000, 128KB DRAM @ 0xC0000000)
      - Custom UART peripheral (0x20010000)
      - CLIC timer/interrupt controller (0x02000000)

config SOC
    default "jv32" if SOC_RISCV_JV32

config SYS_CLOCK_HW_CYCLES_PER_SEC
    default 50000000 if SOC_RISCV_JV32

config RISCV_SOC_INTERRUPT_INIT
    default y if SOC_RISCV_JV32

config NUM_IRQS
    default 32 if SOC_RISCV_JV32

config RISCV_HAS_CPU_IDLE
    bool
    default y if SOC_RISCV_JV32

# Enable RISCV_MACHINE_TIMER for sys_clock
config RISCV_MACHINE_TIMER
    bool
    default y if SOC_RISCV_JV32
