config BOARD_JV32
    bool "jv32 RISC-V Development Board"
    depends on SOC_RISCV_JV32
    help
      Enable support for the jv32 RISC-V development board.
      This board features:
      - RV32IM processor core
      - 2MB RAM
      - UART console
      - CLINT timer/interrupts
